### ============================================================
### Vendor Invoice Management - Service Test Suite
### Requires the "REST Client" extension in VS Code / BAS
### Run: cds watch   (keep it running in a separate terminal)
### Click "Send Request" above any block below to run it.
###
### Mock users (from package.json cds.requires.auth.users):
###   admin     / Admin@123     (Admin, VendorManager, Approver, Viewer)
###   manager1  / Admin@123     (VendorManager)
###   manager2  / @123          (VendorManager)
###   approver1 / Approver@123  (Approver)
###   viewer1   / Viewer@123    (Viewer)
###
### NOTE: Invoices are DRAFT-ENABLED (@odata.draft.enabled).
### Creating one returns a draft (IsActiveEntity=false) that must be
### activated with draftActivate before business actions can run.
### ============================================================

# cds watch default port is 4004; in BAS use the forwarded port shown in the terminal
@baseUrl = http://localhost:4004

# Real IDs from db/data/vendorinvoice.db-Vendors.csv / -Invoices.csv
@approvedVendorId  = 16156972-e7ef-40b3-8e07-3b12fb480727
@approvedVendor2Id = 16156982-f5b5-45b1-ac59-9680ddc5dc6b
@pendingVendorId   = 6648354f-1b9d-462e-a4de-c8c1b7308553
@submittedInvoiceId = 620955ce-3a44-4743-8c35-80ac3868ba74

### ------------------------------------------------------------
### 0. SETUP - assign vendors to managers (seed data has no real
###    manager assignments, so row-level tests need this first)
### ------------------------------------------------------------

### 0.1 Assign Acme-equivalent vendor to manager1
PATCH {{baseUrl}}/odata/v4/admin/Vendors({{approvedVendorId}})
Authorization: Basic admin:Admin@123
Content-Type: application/json

{ "assignedManager": "manager1" }

### 0.2 Assign a different vendor to manager2
PATCH {{baseUrl}}/odata/v4/admin/Vendors({{approvedVendor2Id}})
Authorization: Basic admin:Admin@123
Content-Type: application/json

{ "assignedManager": "manager2" }


### ------------------------------------------------------------
### 1. ADMIN SERVICE
### ------------------------------------------------------------

### 1.1 Get all vendors (Admin sees everything)
GET {{baseUrl}}/odata/v4/admin/Vendors?$top=10
Authorization: Basic admin:Admin@123

### 1.2 Get all invoices
GET {{baseUrl}}/odata/v4/admin/Invoices?$top=10&$count=true
Authorization: Basic admin:Admin@123

### 1.3 Create a new invoice (deep insert with line item) for an APPROVED vendor
# Expected: 201 Created - returns a DRAFT (IsActiveEntity=false)
# @name createInvoice
POST {{baseUrl}}/odata/v4/admin/Invoices
Authorization: Basic admin:Admin@123
Content-Type: application/json

{
  "invoiceNumber": "INV-TEST-001",
  "vendor_ID": "{{approvedVendorId}}",
  "invoiceDate": "2026-06-01",
  "dueDate": "2026-08-01",
  "amount": 10000.00,
  "currency": "USD",
  "items": [
    {
      "lineNumber": 1,
      "description": "Consulting Services",
      "quantity": 2,
      "unitPrice": 5000.00
    }
  ]
}

### ID of the invoice created in 1.3 (captured automatically)
@invoiceId = {{createInvoice.response.body.ID}}

### 1.4 Activate the draft (turns it into a real invoice, status DRAFT)
POST {{baseUrl}}/odata/v4/admin/Invoices(ID={{invoiceId}},IsActiveEntity=false)/AdminService.draftActivate
Authorization: Basic admin:Admin@123
Content-Type: application/json

{}

### 1.5 Try creating an invoice for a PENDING (not approved) vendor
# Expected: 400 error - only approved vendors allowed
POST {{baseUrl}}/odata/v4/admin/Invoices
Authorization: Basic admin:Admin@123
Content-Type: application/json

{
  "invoiceNumber": "INV-TEST-002",
  "vendor_ID": "{{pendingVendorId}}",
  "invoiceDate": "2026-06-01",
  "dueDate": "2026-08-01",
  "amount": 5000.00,
  "currency": "USD"
}

### 1.6 Try a future-dated invoice
# Expected: 400 error - invoice date cannot be in the future
POST {{baseUrl}}/odata/v4/admin/Invoices
Authorization: Basic admin:Admin@123
Content-Type: application/json

{
  "invoiceNumber": "INV-TEST-003",
  "vendor_ID": "{{approvedVendorId}}",
  "invoiceDate": "2027-01-01",
  "dueDate": "2027-02-01",
  "amount": 5000.00,
  "currency": "USD"
}

### 1.7 Try a negative amount
# Expected: 400 error - amount out of range
POST {{baseUrl}}/odata/v4/admin/Invoices
Authorization: Basic admin:Admin@123
Content-Type: application/json

{
  "invoiceNumber": "INV-TEST-004",
  "vendor_ID": "{{approvedVendorId}}",
  "invoiceDate": "2026-06-01",
  "dueDate": "2026-08-01",
  "amount": -100,
  "currency": "USD"
}

### 1.8 Read the activated invoice from 1.3/1.4
GET {{baseUrl}}/odata/v4/admin/Invoices(ID={{invoiceId}},IsActiveEntity=true)?$expand=items
Authorization: Basic admin:Admin@123

### 1.9 Submit for approval (line items total = amount, so this succeeds)
# Expected: status -> SUBMITTED
# NOTE: this also fires the SBPA process trigger (srv/lib/sbpa.js);
# locally without SBPA config it just logs a warning and continues.
POST {{baseUrl}}/odata/v4/admin/Invoices(ID={{invoiceId}},IsActiveEntity=true)/AdminService.submitForApproval
Authorization: Basic admin:Admin@123
Content-Type: application/json

{}

### 1.10 Invoice analytics (grouped by vendor/status/currency)
GET {{baseUrl}}/odata/v4/admin/InvoiceAnalytics?$top=10
Authorization: Basic admin:Admin@123


### ------------------------------------------------------------
### 2. APPROVER SERVICE
### ------------------------------------------------------------

### 2.1 Admin cannot approve their own submitted invoice
# Expected: 400 "You cannot approve your own submitted invoice"
POST {{baseUrl}}/odata/v4/approver/Invoices({{invoiceId}})/ApproverService.approveInvoice
Authorization: Basic admin:Admin@123
Content-Type: application/json

{ "comments": "Trying to approve my own invoice" }

### 2.2 Approver approves the invoice (different user than submitter)
# Expected: status -> APPROVED
POST {{baseUrl}}/odata/v4/approver/Invoices({{invoiceId}})/ApproverService.approveInvoice
Authorization: Basic approver1:Approver@123
Content-Type: application/json

{ "comments": "Invoice approved after document verification" }

### 2.3 Try rejecting the already-approved invoice
# Expected: 400 "Only submitted invoices can be rejected"
POST {{baseUrl}}/odata/v4/approver/Invoices({{invoiceId}})/ApproverService.rejectInvoice
Authorization: Basic approver1:Approver@123
Content-Type: application/json

{ "reason": "Too late, already approved" }

### 2.4a Try to reject a seeded SUBMITTED invoice WITHOUT a reason
# Expected: 400 "Rejection reason is mandatory"
POST {{baseUrl}}/odata/v4/approver/Invoices({{submittedInvoiceId}})/ApproverService.rejectInvoice
Authorization: Basic approver1:Approver@123
Content-Type: application/json

{}

### 2.4b Reject WITH a reason
# Expected: status -> REJECTED
POST {{baseUrl}}/odata/v4/approver/Invoices({{submittedInvoiceId}})/ApproverService.rejectInvoice
Authorization: Basic approver1:Approver@123
Content-Type: application/json

{ "reason": "Missing supporting documents" }

### 2.5 Approver has read access to invoices
GET {{baseUrl}}/odata/v4/approver/Invoices?$top=10
Authorization: Basic approver1:Approver@123


### ------------------------------------------------------------
### 3. VENDOR SERVICE (row-level security)
###    Run section 0 first so manager1/manager2 have vendors!
### ------------------------------------------------------------

### 3.1 manager1 sees ONLY their assigned, APPROVED vendors (1 vendor after 0.1)
GET {{baseUrl}}/odata/v4/vendor/Vendors
Authorization: Basic manager1:Admin@123

### 3.2 manager1 sees ONLY invoices of their assigned vendors
GET {{baseUrl}}/odata/v4/vendor/Invoices?$count=true&$top=10
Authorization: Basic manager1:Admin@123

### 3.3 manager2 sees a DIFFERENT set of vendors/invoices
GET {{baseUrl}}/odata/v4/vendor/Invoices?$count=true&$top=10
Authorization: Basic manager2:@123

### 3.4 manager1 creates an invoice for THEIR OWN vendor - should succeed (draft)
# @name managerInvoice
POST {{baseUrl}}/odata/v4/vendor/Invoices
Authorization: Basic manager1:Admin@123
Content-Type: application/json

{
  "invoiceNumber": "INV-TEST-M1-001",
  "vendor_ID": "{{approvedVendorId}}",
  "invoiceDate": "2026-06-01",
  "dueDate": "2026-08-01",
  "amount": 3000.00,
  "currency": "USD",
  "items": [
    { "lineNumber": 1, "description": "Spare parts", "quantity": 3, "unitPrice": 1000.00 }
  ]
}

@managerInvoiceId = {{managerInvoice.response.body.ID}}

### 3.4b Activate manager1's draft
POST {{baseUrl}}/odata/v4/vendor/Invoices(ID={{managerInvoiceId}},IsActiveEntity=false)/VendorService.draftActivate
Authorization: Basic manager1:Admin@123
Content-Type: application/json

{}

### 3.4c manager1 submits it for approval (fires SBPA trigger)
POST {{baseUrl}}/odata/v4/vendor/Invoices(ID={{managerInvoiceId}},IsActiveEntity=true)/VendorService.submitForApproval
Authorization: Basic manager1:Admin@123
Content-Type: application/json

{}

### 3.5 manager1 tries to create an invoice for manager2's vendor
# Expected: 403/400 "You can only create invoices for your assigned vendors"
POST {{baseUrl}}/odata/v4/vendor/Invoices
Authorization: Basic manager1:Admin@123
Content-Type: application/json

{
  "invoiceNumber": "INV-TEST-M1-002",
  "vendor_ID": "{{approvedVendor2Id}}",
  "invoiceDate": "2026-06-01",
  "dueDate": "2026-08-01",
  "amount": 3000.00,
  "currency": "USD"
}

### 3.6 manager1 tries to read an invoice of an unassigned vendor
# Expected: 404 / empty (row-level security blocks it)
GET {{baseUrl}}/odata/v4/vendor/Invoices(ID={{submittedInvoiceId}},IsActiveEntity=true)
Authorization: Basic manager1:Admin@123


### ------------------------------------------------------------
### 4. VIEWER SERVICE (read-only)
### ------------------------------------------------------------

### 4.1 Viewer sees only APPROVED/PAID invoices
GET {{baseUrl}}/odata/v4/viewer/Invoices?$top=10
Authorization: Basic viewer1:Viewer@123

### 4.2 Viewer sees only APPROVED vendors
GET {{baseUrl}}/odata/v4/viewer/Vendors?$top=10
Authorization: Basic viewer1:Viewer@123

### 4.3 Viewer tries to create an invoice - must fail (read-only service)
# Expected: 403 Forbidden / 405 Method Not Allowed
POST {{baseUrl}}/odata/v4/viewer/Invoices
Authorization: Basic viewer1:Viewer@123
Content-Type: application/json

{
  "invoiceNumber": "INV-SHOULD-FAIL",
  "vendor_ID": "{{approvedVendorId}}",
  "invoiceDate": "2026-06-01",
  "amount": 1000.00,
  "currency": "USD"
}


### ------------------------------------------------------------
### 5. NEGATIVE / UNAUTHORIZED ACCESS
### ------------------------------------------------------------

### 5.1 No credentials at all - should be 401, not an empty array
GET {{baseUrl}}/odata/v4/admin/Invoices

### 5.2 Viewer tries to access the Admin service
# Expected: 403 Forbidden
GET {{baseUrl}}/odata/v4/admin/Invoices
Authorization: Basic viewer1:Viewer@123

### 5.3 manager1 tries the Approver action
# Expected: 403 Forbidden
POST {{baseUrl}}/odata/v4/approver/Invoices({{submittedInvoiceId}})/ApproverService.approveInvoice
Authorization: Basic manager1:Admin@123
Content-Type: application/json

{ "comments": "Manager should not be able to approve" }
